      "parameters": {
        "jsCode": "\nconst cb = $input.first().json.callback_query || $input.first().json;\nconst data = cb.data || '';\nconst sep = data.indexOf(':');\nconst action = sep === -1 ? data : data.slice(0, sep);\nconst recId = sep === -1 ? '' : data.slice(sep + 1);\nconst chatId = cb.message && cb.message.chat ? cb.message.chat.id : undefined;\nconst messageId = cb.message ? cb.message.message_id : undefined;\nconst callbackId = cb.id;\n\nconst inboundActions = ['approve', 'edit', 'reject'];\nconst outboundActions = ['op_approve', 'op_edit', 'op_reject', 'td_approve', 'td_reject'];\n\nlet family;\nif (inboundActions.indexOf(action) !== -1) family = 'inbound';\nelse if (outboundActions.indexOf(action) !== -1) family = 'outbound';\nelse throw new Error('Unknown callback action: ' + action);\n\nreturn [{ json: {\n  family: family,\n  action: action,\n  lead_id: family === 'inbound' ? recId : '',\n  prospect_id: family === 'outbound' ? recId : '',\n  chat_id: chatId,\n  message_id: messageId,\n  callback_id: callbackId,\n} }];\n"
      },
