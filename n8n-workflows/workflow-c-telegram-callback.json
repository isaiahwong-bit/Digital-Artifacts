    {
      "parameters": {
        "jsCode": "\nconst cb = $('Parse Callback').item.json;\nconst row = $input.first().json;\nconst action = cb.action || '';\nconst isTeardown = action.indexOf('td_') === 0;\nconst isApprove = action.indexOf('_approve') !== -1;\nconst isReject = action.indexOf('_reject') !== -1;\nconst oc_action = isApprove ? 'approve' : (isReject ? 'reject' : 'edit');\n\nconst toEmail = String(row.email || '').trim();\nconst subject = isTeardown ? (row.teardown_subject || '') : (row.opener_subject || '');\nconst bodyText = isTeardown ? (row.teardown_body || '') : (row.opener_body || '');\n\nlet new_status;\nif (isApprove) new_status = isTeardown ? 'teardown_sent' : 'opener_sent';\nelse if (isReject) new_status = isTeardown ? 'teardown_rejected' : 'rejected';\nelse new_status = 'editing';\n\nconst now = new Date().toISOString();\n\nconst b64body = Buffer.from(bodyText, 'utf8').toString('base64').replace(/(.{76})/g, '$1\\r\\n');\nconst mime = [\n  'From: Isaiah Wong <isaiah@digitalartifacts.com.au>',\n  'To: ' + toEmail,\n  'Subject: ' + subject,\n  'MIME-Version: 1.0',\n  'Content-Type: text/plain; charset=\"UTF-8\"',\n  'Content-Transfer-Encoding: base64',\n  '',\n  b64body,\n].join('\\r\\n');\nconst send_raw = Buffer.from(mime, 'utf8').toString('base64')\n  .replace(/\\+/g, '-').replace(/\\//g, '_').replace(/=+$/, '');\n\nreturn [{ json: {\n  prospect_id: cb.prospect_id,\n  chat_id: cb.chat_id,\n  message_id: cb.message_id,\n  callback_id: cb.callback_id,\n  business_name: row.business_name || '',\n  email: toEmail,\n  oc_action: oc_action,\n  is_teardown: isTeardown,\n  stage: isTeardown ? 'Teardown' : 'Cold opener',\n  new_status: new_status,\n  now: now,\n  send_subject: subject,\n  send_body: bodyText,\n  send_raw: send_raw,\n} }];\n"
      },
