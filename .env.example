# Digital Artifacts — credentials reference
#
# IMPORTANT: this file is a TEMPLATE only. The static HTML site does not read
# env vars at runtime. These values live in n8n Credentials + Variables on
# your n8n cloud instance (n8nbeginner-sga.app.n8n.cloud).
#
# To use: copy this to .env (gitignored), fill in the values, then paste each
# one into the matching n8n Credential or Variable via the UI. Keep .env local.
# Never commit real values.

# ─── Anthropic ───────────────────────────────────────────────
# Gets the Claude calls working (lead-qualifier + inbound-reply-draft skills).
# Console: https://console.anthropic.com/settings/keys
# In n8n: Credentials → new Header Auth → name: anthropicApi.default
#         Header Name: x-api-key
#         Header Value: (paste key)
ANTHROPIC_API_KEY=

# ─── Telegram (DA_Adminbot) ──────────────────────────────────
# Controls the approval inbox + callback buttons.
# Get a fresh token by messaging @BotFather → /mybots → DA_Adminbot → API Token
# (run /revoke first if the previous token was ever shared anywhere).
# In n8n: Credentials → new Telegram API → name: telegramApi.daAdminbot
TELEGRAM_BOT_TOKEN=

# Your personal Telegram chat ID (the bot DMs you here).
# Get it by messaging @userinfobot and copying the ID number it returns.
# In n8n: Variables → add TELEGRAM_CHAT_ID (used by both workflows).
TELEGRAM_CHAT_ID=

# ─── Google Workspace ────────────────────────────────────────
# Gmail + Sheets credentials are already wired in n8n via OAuth for
# hello@digitalartifacts.com.au. No keys to paste here, but re-auth
# if n8n ever shows a red badge on those nodes.

# ─── Google Calendar booking link ────────────────────────────
# The appointment-schedule URL Claude drops into drafts.
# Source of truth: brain/integrations.md. This is just a staging copy.
BOOKING_LINK=https://calendar.app.google/PLACEHOLDER

# ─── n8n cloud ───────────────────────────────────────────────
# Webhook endpoint the website posts to. Already hardcoded in index.html
# and automations.html. Kept here for reference only.
N8N_WEBHOOK_URL=https://n8nbeginner-sga.app.n8n.cloud/webhook/da-lead-capture

# Optional: n8n personal API key, if you ever want to import workflows
# programmatically instead of via the UI.
# Generate at: n8nbeginner-sga.app.n8n.cloud/settings/api
N8N_API_KEY=

# ─── Formspree ───────────────────────────────────────────────
# Backup form destination (already hardcoded in the HTML).
FORMSPREE_URL=https://formspree.io/f/mreypwgk
